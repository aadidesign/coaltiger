# Coal Tiger Chatbot — environment variables
# Copy to .env for local dev (never commit real keys).

# Your Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model to use
GEMINI_MODEL=gemini-2.0-flash

# Comma-separated allowed browser origins (leave empty to allow all).
# e.g. https://your-site.vercel.app,https://www.coaltigerltd.com
ALLOWED_ORIGINS=

# Local port (Render injects its own PORT automatically)
PORT=8787
